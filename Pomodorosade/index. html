<!DOCTYPE html>
<html lang="tr">
<head>
    <meta charset="UTF-8">
    <meta name="viewport" content="width=device-width, initial-scale=1.0, maximum-scale=1.0, user-scalable=no">
    <title>Odak</title>
    
    <!-- APP (PWA) AYARLARI -->
    <meta name="application-name" content="Odak">
    <meta name="apple-mobile-web-app-title" content="Odak">
    <meta name="theme-color" content="#fcfbf9">
    <meta name="mobile-web-app-capable" content="yes">
    <meta name="apple-mobile-web-app-capable" content="yes">
    <meta name="apple-mobile-web-app-status-bar-style" content="black-translucent">
    
    <!-- UYGULAMA İKONU -->
    <link rel="icon" type="image/svg+xml" href="https://cdn.jsdelivr.net/npm/@lucide/static@0.329.0/icons/brain.svg">
    <link rel="apple-touch-icon" href="https://cdn.jsdelivr.net/npm/@lucide/static@0.329.0/icons/brain.svg">

    <!-- Tailwind CSS -->
    <script src="https://cdn.tailwindcss.com"></script>
    
    <!-- Babel -->
    <script src="https://unpkg.com/@babel/standalone/babel.min.js"></script>

    <style>
        /* Performanslı Animasyon Tanımlamaları (GPU Hızlandırmalı) */
        .animate-wave-linear { animation: wave-linear 18s linear infinite; will-change: transform; }
        .animate-wave-linear-reverse { animation: wave-linear-reverse 14s linear infinite; will-change: transform; }
        
        @keyframes wave-linear {
          0% { transform: translate3d(0, 0, 0); }
          100% { transform: translate3d(-50%, 0, 0); }
        }
        @keyframes wave-linear-reverse {
          0% { transform: translate3d(-50%, 0, 0); }
          100% { transform: translate3d(0, 0, 0); }
        }

        /* Saat Çalışırken Nefes Alma Efekti (Hafifleştirildi) */
        @keyframes gentle-pulse {
            0%, 100% { transform: scale(1); box-shadow: 0 4px 15px -5px rgba(0, 0, 0, 0.1); }
            50% { transform: scale(1.05); box-shadow: 0 10px 20px -5px rgba(0, 0, 0, 0.15); }
        }
        .animate-gentle-pulse { animation: gentle-pulse 3s cubic-bezier(0.4, 0, 0.6, 1) infinite; }

        /* Daha yumuşak font render işlemi */
        body {
            -webkit-font-smoothing: antialiased;
            -moz-osx-font-smoothing: grayscale;
        }
        
        * { -webkit-tap-highlight-color: transparent; }
    </style>
</head>
<body class="overflow-hidden bg-[#fcfbf9] text-[#1f2937]">
    
    <div id="root"></div>
   
    <script type="text/babel" data-type="module">
        import React, { useState, useEffect, useRef } from 'https://esm.sh/react@18.2.0';
        import { createRoot } from 'https://esm.sh/react-dom@18.2.0/client';
        import * as Lucide from 'https://esm.sh/lucide-react@0.294.0';

        const { 
          Play, Pause, RotateCcw, Volume2, 
          Settings, Coffee, Brain, Clock, Upload, 
          Music, BookOpen, X, Target, BellRing, BellOff
        } = Lucide;

        const POMODORO_META = {
          FOCUS: { label: 'Odak Süresi', icon: <Brain className="w-5 h-5" />, color: 'text-emerald-600', stroke: 'stroke-emerald-600', bg: 'bg-emerald-600', lightBg: 'bg-emerald-50', glow: 'shadow-emerald-500/30' },
          SHORT_BREAK: { label: 'Kısa Mola', icon: <Coffee className="w-5 h-5" />, color: 'text-rose-500', stroke: 'stroke-rose-500', bg: 'bg-rose-500', lightBg: 'bg-rose-50', glow: 'shadow-rose-500/30' },
          LONG_BREAK: { label: 'Uzun Mola', icon: <Coffee className="w-5 h-5" />, color: 'text-blue-500', stroke: 'stroke-blue-500', bg: 'bg-blue-500', lightBg: 'bg-blue-50', glow: 'shadow-blue-500/30' }
        };

        const POMODORO_PRESETS = {
          KLASIK: { label: 'Klasik', config: { FOCUS: 25, SHORT_BREAK: 5, LONG_BREAK: 15 } },
          DERIN: { label: 'Derin', config: { FOCUS: 50, SHORT_BREAK: 10, LONG_BREAK: 30 } },
          MIKRO: { label: 'Mikro', config: { FOCUS: 15, SHORT_BREAK: 3, LONG_BREAK: 10 } }
        };

        const AUDIO_TRACKS = [
          { id: 'none', label: '🔇 Sessiz', url: null },
          { id: 'rain', label: '🌧️ Hafif Yağmur', url: 'https://cdn.pixabay.com/download/audio/2021/08/09/audio_8dd922755e.mp3' },
          { id: 'fire', label: '🔥 Şömine Ateşi', url: 'https://cdn.pixabay.com/download/audio/2022/02/07/audio_67e1a38fc2.mp3' },
          { id: 'wind', label: '💨 Rüzgar Sesi', url: 'https://cdn.pixabay.com/download/audio/2022/01/18/audio_d0a13f69d2.mp3' },
          { id: 'birds', label: '🐦 Orman Cıvıltısı', url: 'https://cdn.pixabay.com/download/audio/2021/09/06/audio_40b2f7d54b.mp3' }
        ];

        function App() {
          const [isBookMode, setIsBookMode] = useState(false);
          const [isZenMode, setIsZenMode] = useState(false); 
          const [currentTime, setCurrentTime] = useState(new Date()); 

          // Local Storage'dan veri çekme (Güvenli ve Sistemi Yormaz)
          const loadLocalData = (key, defaultValue) => {
              try {
                  const item = localStorage.getItem(key);
                  return item ? JSON.parse(item) : defaultValue;
              } catch (error) {
                  return defaultValue;
              }
          };

          const [timerConfig, setTimerConfig] = useState(() => loadLocalData('odak_config', { FOCUS: 25, SHORT_BREAK: 5, LONG_BREAK: 15 }));
          const [tempTimerConfig, setTempTimerConfig] = useState(timerConfig);
          const [showTimerSettings, setShowTimerSettings] = useState(false);
          
          const [mode, setMode] = useState('FOCUS');
          const [timeLeft, setTimeLeft] = useState(timerConfig.FOCUS * 60);
          const [isActive, setIsActive] = useState(false);
          
          // Ses ve Bildirim Ayarları
          const [isTicking, setIsTicking] = useState(false);
          const [notificationsEnabled, setNotificationsEnabled] = useState(false);
          
          // İstatistikler (Local Storage)
          const [totalFocusMinutes, setTotalFocusMinutes] = useState(() => loadLocalData('odak_total_minutes', 0));
          const [dailySessions, setDailySessions] = useState(() => {
              const saved = loadLocalData('odak_daily', { count: 0, date: new Date().toDateString() });
              if (saved.date !== new Date().toDateString()) return 0; // Gün değiştiyse sıfırla
              return saved.count;
          });

          const [selectedAudio, setSelectedAudio] = useState(AUDIO_TRACKS[0]);
          const [isPlaying, setIsPlaying] = useState(false);
          const [volume, setVolume] = useState(0.5);

          const audioRef = useRef(null);
          const audioCtxRef = useRef(null);
          const tickStateRef = useRef(true);
          const isTickingRef = useRef(isTicking);
          const zenModeTimerRef = useRef(null); 

          // Uygulama yüklendiğinde bildirim izni durumunu kontrol et
          useEffect(() => {
            if ("Notification" in window && Notification.permission === "granted") {
                setNotificationsEnabled(true);
            }
          }, []);

          // Gerçek Tam Ekran (Fullscreen API) İşlevleri
          const enterFullscreen = () => {
              setIsBookMode(true);
              const elem = document.documentElement;
              try {
                  if (elem.requestFullscreen) {
                      elem.requestFullscreen().catch(() => {});
                  } else if (elem.webkitRequestFullscreen) {
                      elem.webkitRequestFullscreen();
                  } else if (elem.msRequestFullscreen) {
                      elem.msRequestFullscreen();
                  }
              } catch (error) {
                  console.warn("Tam ekran API desteklenmiyor veya engellendi.");
              }
          };

          const exitFullscreen = () => {
              setIsBookMode(false);
              try {
                  if (document.fullscreenElement || document.webkitFullscreenElement || document.msFullscreenElement) {
                      if (document.exitFullscreen) {
                          document.exitFullscreen();
                      } else if (document.webkitExitFullscreen) {
                          document.webkitExitFullscreen();
                      } else if (document.msExitFullscreen) {
                          document.msExitFullscreen();
                      }
                  }
              } catch (error) {
                  console.warn("Tam ekrandan çıkış API hatası.");
              }
          };

          // Bildirim İzni İsteme (Buton ile Tetiklenir)
          const handleNotificationRequest = async () => {
            if (!("Notification" in window)) {
                // Bildirim desteklenmiyorsa sessizce geri dön
                return;
            }
            try {
                const permission = await Notification.requestPermission();
                const isGranted = permission === "granted";
                setNotificationsEnabled(isGranted);
                
                if (isGranted) {
                    new Notification("Harika!", { 
                        body: "Bildirimler başarıyla açıldı. Süre bitiminde size haber vereceğiz.",
                        icon: 'https://cdn.jsdelivr.net/npm/@lucide/static@0.329.0/icons/brain.svg'
                    });
                }
            } catch (error) {
                console.error("Bildirim izni alınırken hata oluştu:", error);
            }
          };

          // Bildirim Gönderme Ana Fonksiyonu
          const sendNotification = (title, body) => {
              if ("Notification" in window && Notification.permission === "granted") {
                  try {
                      new Notification(title, { 
                          body, 
                          icon: 'https://cdn.jsdelivr.net/npm/@lucide/static@0.329.0/icons/brain.svg',
                          requireInteraction: true // Kullanıcı görene kadar ekranda kalmasını teşvik eder
                      });
                  } catch (e) {
                      console.warn("Bildirim gönderilemedi.");
                  }
              }
              // Mobil cihazlar için titreşim (Haptic Feedback)
              if ("vibrate" in navigator) {
                  try {
                      navigator.vibrate([200, 100, 200, 100, 400]);
                  } catch (e) {}
              }
          };

          // Sekme Başlığını Dinamik Olarak Güncelleme
          const formatTime = (seconds) => {
            if (isNaN(seconds)) return "00:00";
            const mins = Math.floor(seconds / 60);
            const secs = Math.floor(seconds % 60);
            return `${mins.toString().padStart(2, '0')}:${secs.toString().padStart(2, '0')}`;
          };

          useEffect(() => {
            document.title = isActive ? `(${formatTime(timeLeft)}) Odak | Pomodoro` : 'Odak | Pomodoro';
          }, [timeLeft, isActive]);

          // İstatistikleri Local Storage'a kaydetme
          useEffect(() => {
              localStorage.setItem('odak_total_minutes', JSON.stringify(totalFocusMinutes));
              localStorage.setItem('odak_daily', JSON.stringify({ count: dailySessions, date: new Date().toDateString() }));
          }, [totalFocusMinutes, dailySessions]);

          // Zen Modu Saati
          useEffect(() => {
            if (!isBookMode) return;
            const timer = setInterval(() => setCurrentTime(new Date()), 1000);
            return () => clearInterval(timer);
          }, [isBookMode]);

          useEffect(() => { isTickingRef.current = isTicking; }, [isTicking]);

          const handleBookInteraction = () => {
            if (isZenMode) setIsZenMode(false);
            if (zenModeTimerRef.current) clearTimeout(zenModeTimerRef.current);
            zenModeTimerRef.current = setTimeout(() => { setIsZenMode(true); }, 4000);
          };

          useEffect(() => {
            if (isBookMode) {
              setIsZenMode(false);
              handleBookInteraction();
            } else {
              if (zenModeTimerRef.current) clearTimeout(zenModeTimerRef.current);
              setIsZenMode(false);
            }
            return () => { if (zenModeTimerRef.current) clearTimeout(zenModeTimerRef.current); };
          }, [isBookMode]);

          // İlk etkileşimde Audio Context başlatma (Tarayıcı politikaları için)
          useEffect(() => {
            const handleFirstInteraction = () => {
              initAudio();
              document.removeEventListener('click', handleFirstInteraction);
              document.removeEventListener('touchstart', handleFirstInteraction);
            };
            document.addEventListener('click', handleFirstInteraction);
            document.addEventListener('touchstart', handleFirstInteraction);
            return () => {
              document.removeEventListener('click', handleFirstInteraction);
              document.removeEventListener('touchstart', handleFirstInteraction);
            };
          }, []);

          const initAudio = () => {
            try {
              if (!audioCtxRef.current) {
                const AudioContext = window.AudioContext || window.webkitAudioContext;
                if (AudioContext) audioCtxRef.current = new AudioContext();
              }
              if (audioCtxRef.current && audioCtxRef.current.state === 'suspended') {
                audioCtxRef.current.resume();
              }
            } catch (e) {}
          };

          const playTickSound = () => {
            try {
              if (!audioCtxRef.current || !isTickingRef.current) return;
              const ctx = audioCtxRef.current;
              const osc = ctx.createOscillator();
              const gain = ctx.createGain();
              osc.connect(gain); 
              gain.connect(ctx.destination);
              osc.type = 'sine';
              
              const isTick = tickStateRef.current;
              tickStateRef.current = !isTick;
              
              osc.frequency.setValueAtTime(isTick ? 700 : 550, ctx.currentTime);
              osc.frequency.exponentialRampToValueAtTime(100, ctx.currentTime + 0.05);
              
              gain.gain.setValueAtTime(0.06, ctx.currentTime);
              gain.gain.exponentialRampToValueAtTime(0.001, ctx.currentTime + 0.05);
              
              osc.start(ctx.currentTime); 
              osc.stop(ctx.currentTime + 0.05);
            } catch (e) {}
          };

          const playBellSound = () => {
            try {
              initAudio();
              if (!audioCtxRef.current) return;
              const ctx = audioCtxRef.current;
              const gainNode = ctx.createGain(); gainNode.connect(ctx.destination);
              const osc1 = ctx.createOscillator(); const osc2 = ctx.createOscillator();
              osc1.connect(gainNode); osc2.connect(gainNode);
              osc1.type = 'sine'; osc1.frequency.setValueAtTime(600, ctx.currentTime);
              osc2.type = 'sine'; osc2.frequency.setValueAtTime(606, ctx.currentTime);
              gainNode.gain.setValueAtTime(0, ctx.currentTime);
              gainNode.gain.linearRampToValueAtTime(0.4, ctx.currentTime + 0.05);
              gainNode.gain.exponentialRampToValueAtTime(0.001, ctx.currentTime + 4);
              osc1.start(ctx.currentTime); osc2.start(ctx.currentTime);
              osc1.stop(ctx.currentTime + 4); osc2.stop(ctx.currentTime + 4);
            } catch (e) {}
          };

          useEffect(() => {
            if (!audioRef.current) return;
            audioRef.current.volume = volume;
            if (isPlaying && selectedAudio?.url) {
              audioRef.current.play().catch(e => setIsPlaying(false));
            } else {
              audioRef.current.pause();
            }
          }, [isPlaying, selectedAudio, volume]);

          const handleAudioSelect = (e) => {
            const track = AUDIO_TRACKS.find(t => t.id === e.target.value);
            if(track) {
              setSelectedAudio(track);
              setIsPlaying(!!track.url); 
            }
          };

          const handleCustomAudioUpload = (e) => {
            const file = e.target.files[0];
            if (file) {
              const url = URL.createObjectURL(file);
              const customTrack = { id: 'custom', label: `🎵 ${file.name.substring(0, 20)}...`, url: url };
              setSelectedAudio(customTrack);
              setIsPlaying(true);
            }
            e.target.value = null;
          };

          const toggleAudio = () => {
            if (!selectedAudio.url) return;
            setIsPlaying(!isPlaying);
          };

          useEffect(() => {
            if (!isActive) setTimeLeft(timerConfig[mode] * 60);
          }, [timerConfig, mode]);

          useEffect(() => {
            let interval = null;
            if (isActive && timeLeft > 0) {
              interval = setInterval(() => {
                setTimeLeft((time) => time - 1);
                playTickSound();
              }, 1000);
            } else if (timeLeft === 0 && isActive) {
              clearInterval(interval);
              handleTimerComplete();
            }
            return () => {
                if (interval) clearInterval(interval);
            };
          }, [isActive, timeLeft]);

          const handleTimerComplete = () => {
            setIsActive(false);
            playBellSound();
            
            if (mode === 'FOCUS') {
              const addedMinutes = timerConfig.FOCUS;
              setTotalFocusMinutes(prev => prev + addedMinutes);
              setDailySessions(prev => prev + 1);
              sendNotification("Odak Seansı Tamamlandı!", "Harika iş çıkardın. Şimdi kısa bir mola zamanı.");
              switchMode('SHORT_BREAK');
            } else {
              sendNotification("Mola Bitti!", "Yeniden odaklanma zamanı geldi. Hadi başlayalım.");
              switchMode('FOCUS');
            }
          };

          const switchMode = (newMode) => {
            setMode(newMode);
            setTimeLeft(timerConfig[newMode] * 60);
            setIsActive(false); 
          };

          const toggleTimer = () => {
            initAudio();
            
            // Haptic feedback
            if("vibrate" in navigator) {
                try { navigator.vibrate(50); } catch(e){}
            }
            
            setIsActive(!isActive);
          };

          const toggleTicking = () => {
            initAudio();
            setIsTicking(!isTicking);
          };

          const resetTimer = () => {
            setIsActive(false);
            setTimeLeft(timerConfig[mode] * 60);
          };

          const saveTimerSettings = () => {
            setTimerConfig(tempTimerConfig);
            localStorage.setItem('odak_config', JSON.stringify(tempTimerConfig));
            setShowTimerSettings(false);
            setTimeLeft(tempTimerConfig[mode] * 60);
          };

          // Dairesel ilerleme hesaplamaları
          const progressPercentage = ((timerConfig[mode] * 60 - timeLeft) / (timerConfig[mode] * 60)) * 100;
          const circleCircumference = 2 * Math.PI * 54; 
          const strokeDashoffset = circleCircumference - (progressPercentage / 100) * circleCircumference;
          
          const bookCircleRadius = 140;
          const bookCircleCircumference = 2 * Math.PI * bookCircleRadius;
          const bookStrokeDashoffset = bookCircleCircumference - (progressPercentage / 100) * bookCircleCircumference;

          const currentState = POMODORO_META[mode];
          const isWaterVisible = progressPercentage > 0;
          
          const getWaveColor = () => {
            if (mode === 'FOCUS') return 'text-emerald-500 bg-emerald-500';
            if (mode === 'SHORT_BREAK') return 'text-rose-500 bg-rose-500';
            return 'text-blue-500 bg-blue-500';
          };
          const waveColor = getWaveColor();

          return (
            <div className={`min-h-screen w-full flex items-center justify-center font-sans transition-all duration-1000 overflow-hidden ${currentState.lightBg}`}>
              <audio ref={audioRef} src={selectedAudio?.url || ''} loop preload="auto" />

              {/* ANA KART (PROFESYONEL POMODORO) */}
              {!isBookMode && (
                <div className={`w-full max-w-[420px] mx-auto p-7 sm:p-9 rounded-[2.5rem] bg-white/80 backdrop-blur-xl shadow-[0_20px_60px_-15px_rgba(0,0,0,0.1)] border border-white relative flex flex-col gap-7 animate-in fade-in zoom-in-95 duration-700`}>
                  
                  {/* Başlık ve Toplam Odak */}
                  <div className="flex items-center justify-between">
                    <div className="flex items-center gap-3">
                        <div className={`p-2.5 text-white rounded-2xl shadow-lg ${currentState.bg} ${currentState.glow} transition-all duration-500`}>
                            <Brain className="w-5 h-5" />
                        </div>
                        <div>
                            <h1 className="text-xl font-extrabold tracking-tight text-gray-900">Odak</h1>
                            <div className="flex gap-1 mt-1">
                                {[...Array(4)].map((_, i) => (
                                    <div key={i} className={`w-2.5 h-2.5 rounded-full transition-all duration-500 ${i < (dailySessions % 4 || (dailySessions > 0 ? 4 : 0)) ? currentState.bg : 'bg-gray-200'}`}></div>
                                ))}
                            </div>
                        </div>
                    </div>
                    <div className="text-right flex flex-col items-end">
                        <p className="text-[10px] font-bold text-gray-400 uppercase tracking-widest mb-0.5">Toplam</p>
                        <p className="text-xl font-black text-gray-800">{totalFocusMinutes} <span className="text-sm font-semibold text-gray-500">dk</span></p>
                    </div>
                  </div>

                  {/* Sayaç Modları (Odak, Kısa Mola, Uzun Mola) */}
                  <div className="flex flex-col items-center gap-4">
                      <div className="flex w-full items-center gap-2">
                        <div className="flex gap-1 p-1.5 bg-gray-100/80 rounded-2xl flex-1 justify-between shadow-inner">
                          {Object.keys(POMODORO_META).map(m => (
                            <button
                              key={m}
                              onClick={() => switchMode(m)}
                              className={`flex-1 py-2.5 px-1 rounded-xl text-xs font-bold transition-all duration-300 ${mode === m ? 'bg-white text-gray-900 shadow-sm scale-[1.02]' : 'text-gray-500 hover:text-gray-900 hover:bg-black/5'}`}
                            >
                              {POMODORO_META[m].label}
                            </button>
                          ))}
                        </div>
                        <button 
                          onClick={() => setShowTimerSettings(!showTimerSettings)} 
                          className={`p-3 rounded-2xl transition-all duration-300 ${showTimerSettings ? 'bg-gray-800 text-white shadow-md' : 'bg-gray-100/80 text-gray-500 hover:bg-gray-200 active:scale-95'}`}
                        >
                          <Settings size={18} />
                        </button>
                      </div>

                      {/* Süre Ayarları Paneli */}
                      {showTimerSettings && (
                        <div className="w-full bg-white p-5 rounded-2xl animate-in fade-in slide-in-from-top-2 duration-300 shadow-xl border border-gray-100 z-10">
                          <h4 className="text-xs font-bold text-gray-500 mb-4 flex items-center gap-2 uppercase tracking-wide"><Settings className="w-3.5 h-3.5" /> Ayarlar</h4>
                          
                          <div className="flex gap-2 mb-5">
                            {Object.entries(POMODORO_PRESETS).map(([key, preset]) => (
                              <button
                                key={key}
                                onClick={() => setTempTimerConfig(preset.config)}
                                className="flex-1 py-2 px-1 bg-gray-50 rounded-xl text-[10px] sm:text-xs font-bold border border-gray-200 hover:bg-gray-100 text-gray-600 transition-all active:scale-95"
                              >
                                {preset.label}
                              </button>
                            ))}
                          </div>

                          <div className="space-y-4">
                            <div className="flex justify-between items-center">
                              <span className="text-sm font-bold text-gray-700">Odak (dk):</span>
                              <input type="number" min="1" max="120" value={tempTimerConfig.FOCUS} onChange={e => setTempTimerConfig({...tempTimerConfig, FOCUS: Number(e.target.value)})} className="w-20 p-2 text-center rounded-xl bg-gray-50 border border-gray-200 focus:border-gray-800 focus:ring-2 focus:ring-gray-800/20 text-sm font-black outline-none transition-all" />
                            </div>
                            <div className="flex justify-between items-center">
                              <span className="text-sm font-bold text-gray-700">Kısa Mola:</span>
                              <input type="number" min="1" max="30" value={tempTimerConfig.SHORT_BREAK} onChange={e => setTempTimerConfig({...tempTimerConfig, SHORT_BREAK: Number(e.target.value)})} className="w-20 p-2 text-center rounded-xl bg-gray-50 border border-gray-200 focus:border-gray-800 focus:ring-2 focus:ring-gray-800/20 text-sm font-black outline-none transition-all" />
                            </div>
                            <div className="flex justify-between items-center">
                              <span className="text-sm font-bold text-gray-700">Uzun Mola:</span>
                              <input type="number" min="1" max="60" value={tempTimerConfig.LONG_BREAK} onChange={e => setTempTimerConfig({...tempTimerConfig, LONG_BREAK: Number(e.target.value)})} className="w-20 p-2 text-center rounded-xl bg-gray-50 border border-gray-200 focus:border-gray-800 focus:ring-2 focus:ring-gray-800/20 text-sm font-black outline-none transition-all" />
                            </div>
                            
                            <div className="pt-2 flex gap-2">
                                <button onClick={handleNotificationRequest} className={`flex-1 py-3 rounded-xl text-xs font-bold transition-all flex items-center justify-center gap-2 ${notificationsEnabled ? 'bg-emerald-50 text-emerald-600 border border-emerald-200' : 'bg-gray-50 text-gray-500 border border-gray-200 hover:bg-gray-100'}`}>
                                    {notificationsEnabled ? <BellRing size={16}/> : <BellOff size={16}/>} 
                                    {notificationsEnabled ? 'Bildirimler Açık' : 'Bildirimleri Aç'}
                                </button>
                                <button onClick={saveTimerSettings} className="flex-1 py-3 bg-gray-900 text-white rounded-xl text-xs font-bold hover:bg-gray-800 shadow-md active:scale-95 transition-all">Kaydet</button>
                            </div>
                          </div>
                        </div>
                      )}

                      {/* Profesyonel SVG Dairesel Sayaç */}
                      <div className="relative w-56 h-56 mx-auto flex items-center justify-center group cursor-pointer my-2" onClick={toggleTimer}>
                        <svg className="w-full h-full transform -rotate-90 drop-shadow-sm" viewBox="0 0 120 120">
                          <circle cx="60" cy="60" r="54" stroke="currentColor" strokeWidth="4" fill="transparent" className="text-gray-200 transition-opacity duration-300" />
                          <circle cx="60" cy="60" r="54" stroke="currentColor" strokeWidth="5" fill="transparent" strokeDasharray={circleCircumference} strokeDashoffset={strokeDashoffset} className={`${currentState.stroke} transition-all duration-1000 ease-in-out drop-shadow-md`} strokeLinecap="round" />
                        </svg>
                        <div className="absolute inset-0 flex flex-col items-center justify-center transition-transform duration-300 group-hover:scale-105">
                          <span className="text-5xl font-black font-mono tracking-tighter text-gray-800">{formatTime(timeLeft)}</span>
                        </div>
                      </div>

                      {/* Oynat / Durdur / Sıfırla Kontrolleri */}
                      <div className="flex items-center justify-center gap-6 w-full">
                        <button onClick={resetTimer} className="p-3.5 rounded-2xl bg-gray-100 text-gray-500 hover:bg-gray-200 hover:text-gray-800 active:rotate-180 transition-all duration-500" title="Sıfırla">
                          <RotateCcw size={20} />
                        </button>
                        
                        {/* Play Butonu: Aktifken nazikçe büyüyüp küçülür (pulse) */}
                        <button onClick={toggleTimer} className={`p-6 rounded-[2rem] text-white shadow-xl transition-all duration-300 hover:scale-110 active:scale-95 hover:shadow-2xl ${currentState.bg} ${isActive ? 'animate-gentle-pulse ' + currentState.glow : ''}`}>
                          {isActive ? <Pause size={32} /> : <Play size={32} className="ml-1" fill="currentColor" />}
                        </button>
                        
                        <button onClick={toggleTicking} className={`p-3.5 rounded-2xl transition-all duration-300 active:scale-90 ${isTicking ? 'bg-gray-800 text-white shadow-md' : 'bg-gray-100 text-gray-500 hover:bg-gray-200 hover:text-gray-800'}`} title="Tik-Tak Sesi">
                           <Clock size={20} />
                        </button>
                      </div>
                  </div>

                  <hr className={`border-gray-100 my-0`} />

                  {/* Ses ve Odak Modu Ayarları */}
                  <div className="flex flex-col gap-3">
                      <div className="flex items-center gap-2">
                        <div className="relative flex-1">
                            <Music className="absolute left-3 top-3.5 w-4 h-4 text-gray-400" />
                            <select 
                                value={selectedAudio.id} 
                                onChange={handleAudioSelect}
                                className={`w-full p-3.5 pl-10 rounded-2xl bg-gray-50 border border-gray-100 hover:bg-gray-100 outline-none font-bold text-sm transition-colors cursor-pointer text-gray-700 appearance-none`}
                            >
                                {AUDIO_TRACKS.map(t => <option key={t.id} value={t.id}>{t.label}</option>)}
                                {selectedAudio.id === 'custom' && <option value="custom">{selectedAudio.label}</option>}
                            </select>
                        </div>
                        <label className={`p-3.5 rounded-2xl border border-dashed border-gray-300 bg-gray-50 hover:bg-gray-100 cursor-pointer transition-all duration-300 flex items-center justify-center text-gray-500 hover:text-gray-800`} title="Kendi Sesini Yükle">
                          <Upload className="w-5 h-5 transition-colors" />
                          <input type="file" accept="audio/*" onChange={handleCustomAudioUpload} className="hidden" />
                        </label>
                      </div>

                      <div className="flex items-center gap-4 bg-gray-50 p-4 rounded-2xl border border-gray-100">
                        <button onClick={toggleAudio} disabled={!selectedAudio.url} className={`p-2.5 rounded-xl transition-all duration-300 active:scale-90 disabled:opacity-40 disabled:active:scale-100 ${isPlaying ? 'bg-gray-800 text-white shadow-md' : 'bg-white text-gray-500 hover:bg-white/80 border border-gray-200'}`}>
                          {isPlaying ? <Pause size={18} /> : <Play size={18} className="ml-0.5" />}
                        </button>
                        <Volume2 size={16} className="text-gray-400" />
                        <input 
                          type="range" min="0" max="1" step="0.01" 
                          value={volume} onChange={(e) => setVolume(parseFloat(e.target.value))}
                          className="w-full accent-gray-800 h-1.5 bg-gray-200 rounded-full appearance-none cursor-pointer hover:bg-gray-300 transition-colors" 
                        />
                      </div>
                  </div>

                  {/* Tam Ekran Modu */}
                  <button 
                    onClick={enterFullscreen}
                    className="w-full py-4 bg-gray-50 hover:bg-gray-100 text-gray-600 hover:text-gray-900 rounded-2xl text-sm font-bold flex items-center justify-center gap-2 transition-all duration-300 active:scale-95 border border-gray-200"
                  >
                    <BookOpen size={18} /> Tam Ekran Odak Modu
                  </button>

                </div>
              )}

              {/* FİZİKSEL KİTAP (ZEN) MODU OVERLAY'I (Optimize Edildi) */}
              {isBookMode && (
                <div 
                  className={`fixed inset-0 z-[100] flex flex-col items-center justify-center animate-in fade-in zoom-in-95 duration-500 text-white bg-gray-900`}
                  onMouseMove={handleBookInteraction}
                  onTouchStart={handleBookInteraction}
                  onClick={handleBookInteraction}
                >
                  
                  <div 
                    className="absolute inset-0 z-0 cursor-pointer" 
                    onClick={(e) => {
                      e.stopPropagation();
                      if (!isZenMode) {
                        setIsZenMode(true);
                        if (zenModeTimerRef.current) clearTimeout(zenModeTimerRef.current);
                      } else {
                        handleBookInteraction();
                      }
                    }}
                  ></div>

                  {/* Dalga Animasyonları (Sistemi Yormaması İçin Optimize Edildi: 3 yerine 2 Katman) */}
                  <div 
                    className={`absolute bottom-0 left-0 w-full z-[-1] pointer-events-none transition-transform duration-[2000ms] ease-in-out ${isWaterVisible ? 'opacity-100' : 'opacity-0'}`} 
                    style={{ height: '100vh', transform: `translateY(${100 - progressPercentage}%)` }}
                  >
                    <div className={`absolute top-0 left-0 w-[200%] h-full opacity-[0.20] animate-wave-linear ${waveColor}`}>
                      <svg className="absolute bottom-[calc(100%-2px)] left-0 w-full h-[10vh] fill-current" viewBox="0 0 1200 120" preserveAspectRatio="none"><path d="M0,60 Q150,10 300,60 T600,60 Q750,10 900,60 T1200,60 L1200,120 L0,120 Z" /></svg>
                      <div className="absolute top-0 left-0 w-full h-full bg-current"></div>
                    </div>
                    <div className={`absolute top-0 left-0 w-[200%] h-full opacity-[0.35] animate-wave-linear-reverse ${waveColor}`}>
                      <svg className="absolute bottom-[calc(100%-2px)] left-0 w-full h-[14vh] fill-current" viewBox="0 0 1200 120" preserveAspectRatio="none"><path d="M0,80 Q150,0 300,80 T600,80 Q750,0 900,80 T1200,80 L1200,120 L0,120 Z" /></svg>
                      <div className="absolute top-0 left-0 w-full h-full bg-current"><div className="absolute inset-0 bg-gradient-to-t from-black/20 to-transparent"></div></div>
                    </div>
                  </div>

                  <div className={`absolute top-8 left-8 font-mono font-bold text-xl opacity-50 tracking-wider transition-opacity duration-700 pointer-events-none z-10 ${isZenMode ? 'opacity-0' : 'opacity-80'}`}>
                    {formatClock(currentTime)}
                  </div>

                  <button 
                    onClick={exitFullscreen} 
                    className={`absolute top-6 right-6 p-4 rounded-full bg-white/10 hover:bg-white/20 border border-white/10 transition-all duration-700 active:scale-90 z-10 group ${isZenMode ? 'opacity-0 translate-y-[-20px] pointer-events-none' : 'opacity-100 translate-y-0'}`}
                    title="Moddan Çık"
                  >
                    <X size={28} className="opacity-80 group-hover:opacity-100" />
                  </button>

                  {/* Tam Ekran Sayaç */}
                  <div className="relative w-64 h-64 sm:w-96 sm:h-96 flex items-center justify-center mb-12 group cursor-pointer z-10" onClick={toggleTimer}>
                    <svg className="w-full h-full transform -rotate-90 hidden sm:block">
                      <circle cx="50%" cy="50%" r={bookCircleRadius} stroke="currentColor" strokeWidth="6" fill="transparent" className="opacity-[0.15] transition-opacity duration-300 group-hover:opacity-[0.25]" />
                      <circle cx="50%" cy="50%" r={bookCircleRadius} stroke="currentColor" strokeWidth="8" fill="transparent" strokeDasharray={bookCircleCircumference} strokeDashoffset={bookStrokeDashoffset} className={`${currentState.stroke} transition-all duration-1000 ease-linear`} strokeLinecap="round" />
                    </svg>
                    <svg className="w-full h-full transform -rotate-90 block sm:hidden">
                      <circle cx="50%" cy="50%" r="45%" stroke="currentColor" strokeWidth="4" fill="transparent" className="opacity-[0.15] transition-opacity duration-300 group-hover:opacity-[0.25]" />
                      <circle cx="50%" cy="50%" r="45%" stroke="currentColor" strokeWidth="6" fill="transparent" strokeDasharray="283%" strokeDashoffset={`${283 - (progressPercentage / 100) * 283}%`} className={`${currentState.stroke} transition-all duration-1000 ease-linear`} strokeLinecap="round" />
                    </svg>
                    <div className="absolute inset-0 flex flex-col items-center justify-center transition-transform duration-300 group-hover:scale-105">
                      <span className="text-6xl sm:text-8xl font-black font-mono tracking-tighter drop-shadow-lg">{formatTime(timeLeft)}</span>
                      <span className={`text-sm sm:text-xl font-bold mt-4 uppercase tracking-widest ${currentState.color} transition-colors duration-500 drop-shadow-md`}>
                        {currentState.label}
                      </span>
                    </div>
                  </div>

                  <div className={`absolute bottom-[10%] left-0 w-full px-6 flex flex-col items-center z-10 transition-all duration-[1200ms] ease-[cubic-bezier(0.23,1,0.32,1)] pointer-events-none ${isZenMode ? 'opacity-100 translate-y-0' : 'opacity-0 translate-y-12'}`}>
                      <div className="flex flex-col items-center gap-3 opacity-40 text-white">
                        <Target size={24} />
                        <span className="text-sm font-bold uppercase tracking-widest">Sadece Odaklan</span>
                      </div>
                  </div>

                  {/* Tam Ekran Alt Kontroller */}
                  <div className={`flex flex-col items-center gap-8 w-full px-6 z-10 transition-all duration-700 ease-[cubic-bezier(0.23,1,0.32,1)] ${isZenMode ? 'opacity-0 translate-y-12 pointer-events-none' : 'opacity-100 translate-y-0'}`}>
                    
                    <div className="flex items-center gap-6">
                      <button onClick={resetTimer} className="p-5 rounded-full bg-white/10 hover:bg-white/20 border border-white/10 active:rotate-180 transition-all duration-500" title="Sıfırla">
                        <RotateCcw size={24} className="opacity-90" />
                      </button>
                      <button onClick={toggleTimer} className={`p-8 rounded-full text-white transition-all duration-300 hover:scale-110 active:scale-95 ${currentState.bg} ${isActive ? 'animate-gentle-pulse ' + currentState.glow : ''}`}>
                        {isActive ? <Pause size={32} /> : <Play size={32} className="ml-1.5" fill="currentColor" />}
                      </button>
                      <button onClick={toggleTicking} className={`p-5 rounded-full transition-all duration-300 active:scale-90 ${isTicking ? 'bg-white text-gray-900' : 'bg-white/10 hover:bg-white/20 border border-white/10'}`} title="Tik-Tak Sesi">
                         <Clock size={24} className={isTicking ? '' : 'opacity-90'} />
                      </button>
                    </div>

                    <div className="flex bg-white/10 p-2 rounded-2xl border border-white/20 w-full max-w-[340px]">
                      {Object.keys(POMODORO_META).map(m => (
                        <button
                          key={m}
                          onClick={() => switchMode(m)}
                          className={`flex-1 py-2.5 rounded-xl text-xs font-bold transition-all duration-500 ${mode === m ? `bg-white text-gray-900` : 'opacity-60 hover:opacity-100 text-white hover:bg-white/10'}`}
                        >
                          {POMODORO_META[m].label.split(' ')[0]}
                        </button>
                      ))}
                    </div>

                    {selectedAudio.url && (
                       <div className="flex items-center gap-4 w-full max-w-xs animate-in slide-in-from-bottom-2 bg-white/10 px-5 py-3.5 rounded-2xl border border-white/20 text-white">
                         <Volume2 size={18} className="opacity-70" />
                         <input 
                            type="range" min="0" max="1" step="0.01" 
                            value={volume} onChange={(e) => setVolume(parseFloat(e.target.value))}
                            className="w-full accent-white h-1.5 bg-black/20 rounded-full appearance-none cursor-pointer hover:bg-black/30 transition-colors" 
                          />
                       </div>
                    )}
                  </div>
                </div>
              )}
            </div>
          );
        }

        const root = createRoot(document.getElementById('root'));
        root.render(<App />);
    </script>
</body>
</html>


